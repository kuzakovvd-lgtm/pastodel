---
const stats = [
  {
    value: "350+ млрд ₽",
    caption: "объём рынка замороженных полуфабрикатов",
  },
  {
    value: "600 млрд ₽ к 2028",
    caption: "потенциал роста категории",
  },
  {
    value: "Готовая еда растёт быстрее FMCG",
    caption: "категория с высоким потребительским спросом",
  },
];
---

<section class="stats-section" aria-labelledby="stats-title">
  <div class="container">
    <h2 class="sr-only" id="stats-title">Преимущества и рыночные показатели</h2>
    <div class="stats-section__grid">
      {stats.map((item, index) => (
        <article class:list={["stats-card", index === 1 && "stats-card--featured"]}>
          <p class="stats-card__value">{item.value}</p>
          <p class="stats-card__caption">{item.caption}</p>
        </article>
      ))}
    </div>
    <p class="stats-section__note">
      Для сетей — понятный продукт, массовый спрос и быстрый путь к запуску.
    </p>
  </div>
</section>

<style>
  .stats-section {
    padding: 0 0 clamp(72px, 8vw, 112px);
  }

  .stats-section__grid {
    display: grid;
    gap: 18px;
  }

  .stats-card {
    position: relative;
    display: grid;
    align-content: start;
    padding: 28px;
    border: 1px solid var(--border);
    border-radius: 24px;
    background: var(--main-surface);
    box-shadow: 0 14px 28px rgba(36, 28, 24, 0.035);
  }

  .stats-card::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.28), transparent 48%);
    pointer-events: none;
  }

  .stats-card--featured {
    background: linear-gradient(180deg, rgba(255, 253, 249, 0.98), rgba(244, 235, 225, 0.95));
    box-shadow: 0 18px 34px rgba(36, 28, 24, 0.05);
  }

  .stats-card__value {
    margin: 0 0 12px;
    color: var(--text-primary);
    font-family: var(--font-serif);
    font-size: clamp(1.85rem, 3.3vw, 2.65rem);
    line-height: 1.02;
    letter-spacing: -0.03em;
  }

  .stats-card__caption {
    margin: 0;
    max-width: 22ch;
    color: var(--text-secondary);
    font-size: 0.985rem;
    line-height: 1.58;
  }

  .stats-section__note {
    margin: 24px 0 0;
    color: var(--text-secondary);
    font-size: 1.04rem;
    line-height: 1.62;
  }

  @media (min-width: 860px) {
    .stats-section__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 719px) {
    .stats-card {
      padding: 24px 22px;
    }

    .stats-card__value {
      max-width: 11ch;
    }
  }
</style>

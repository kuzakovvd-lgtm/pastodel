---
import { brand, navigation } from "../data/site";

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/"
    ? pathname === "/"
    : pathname === href || pathname.startsWith(href);
---

<header class="site-header">
  <div class="container nav-shell">
    <a class="brand-mark" href="/" aria-label={`${brand.name} — на главную`}>
      <span class="brand-mark__symbol">P</span>
      <span class="brand-mark__copy">
        <strong>{brand.name}</strong>
        <span>готовая замороженная паста</span>
      </span>
    </a>

    <nav aria-label="Основная навигация">
      <ul class="nav-list">
        {navigation.map((item) => (
          <li>
            <a class:list={{ active: isActive(item.href) }} href={item.href}>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

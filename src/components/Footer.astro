---
import { brand } from "../data/site";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container site-footer__grid">
    <div class="site-footer__brand">
      <a class="brand-mark brand-mark--footer" href="/">
        <span class="brand-mark__symbol" aria-hidden="true">P</span>
        <span class="brand-mark__copy">
          <strong>{brand.name}</strong>
          <span>готовые замороженные блюда</span>
        </span>
      </a>
      <p class="site-footer__text">
        Готовые замороженные блюда для быстрого и понятного выбора.
      </p>
      <p class="site-footer__text site-footer__text--muted">
        Pastodel — линейка готовых замороженных блюд с понятными вкусами и
        удобным сценарием приготовления.
      </p>
      <div class="pd-footer-cta">
        <a class="pd-button" href="/kontakty/">Написать нам</a>
        <p class="pd-form-note">Используйте форму запроса на странице «Контакты».</p>
      </div>
    </div>

    <div class="site-footer__contacts">
      <p class="site-footer__title">Разделы</p>
      <ul class="site-footer__list">
        <li><a href="/partneram/">Для сетей</a></li>
        <li><a href="/gde-kupit/">Где купить</a></li>
        <li><a href="/kontakty/">Контакты</a></li>
        <li><a href="/politika-konfidentsialnosti/">Политика конфиденциальности</a></li>
      </ul>
    </div>

    <div class="site-footer__meta">
      <p class="site-footer__copyright">© {year} {brand.name}</p>
    </div>
  </div>
</footer>

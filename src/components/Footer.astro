---
import { brand, companyLinks, legalLinks, navigation } from "../data/site";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-block">
      <a class="brand-mark brand-mark--footer" href="/">
        <span class="brand-mark__symbol">P</span>
        <span class="brand-mark__copy">
          <strong>{brand.name}</strong>
          <span>{brand.slogan}</span>
        </span>
      </a>
    </div>

    <div class="footer-block">
      <p class="footer-title">Навигация</p>
      <ul class="footer-list">
        {navigation.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="footer-block">
      <p class="footer-title">Маршруты</p>
      <ul class="footer-list">
        <li><a href="/partneram/">Для сетей</a></li>
        <li><a href="/kontakty/">Контакты</a></li>
        <li><a href="/gde-kupit/">Где купить</a></li>
      </ul>
    </div>

    <div class="footer-block">
      <p class="footer-title">Компания и legal</p>
      <ul class="footer-list">
        {companyLinks.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
        {legalLinks.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </div>
  </div>

  <div class="container footer-meta">
    <p>© {year} {brand.name}. Статический сайт производителя для продуктового и B2B-сценария.</p>
    <p>Юридические тексты требуют финальной проверки перед публикацией.</p>
  </div>
</footer>

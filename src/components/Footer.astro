---
import { brand, navigation } from "../data/site";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-block">
      <a class="brand-mark brand-mark--footer" href="/">
        <span class="brand-mark__symbol">P</span>
        <span class="brand-mark__copy">
          <strong>{brand.name}</strong>
          <span>{brand.slogan}</span>
        </span>
      </a>
    </div>

    <div class="footer-block">
      <p class="footer-title">Навигация</p>
      <ul class="footer-list">
        {navigation.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="footer-block">
      <p class="footer-title">Контакты</p>
      <ul class="footer-list">
        <li><a href={`tel:${brand.phone.replace(/[^\d+]/g, "")}`}>{brand.phone}</a></li>
        <li><a href={`mailto:${brand.email}`}>{brand.email}</a></li>
        <li>{brand.address}</li>
      </ul>
    </div>
  </div>

  <div class="container footer-meta">
    <p>© {year} {brand.legalName}. Все права защищены.</p>
    <p>ИНН {brand.inn} • ОГРН {brand.ogrn}</p>
  </div>
</footer>

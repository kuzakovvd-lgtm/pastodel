---
import ProductImage from "./ProductImage.astro";
import { flavorLabels, type Product } from "../data/products";

interface Props {
  product: Product;
  showHighlights?: boolean;
  showNetworkCta?: boolean;
  primaryLabel?: string;
}

const {
  product,
  showHighlights = false,
  showNetworkCta = false,
  primaryLabel = "Смотреть продукт",
} = Astro.props;
---

<article
  class="product-card"
  data-card
  data-line={product.line}
  data-flavors={product.flavorKeys.join(" ")}
>
  <a class="product-card__media" href={`/katalog/${product.slug}/`}>
    <ProductImage src={product.image} alt={product.title} />
  </a>

  <div class="product-card__content">
    <div class="product-card__meta">
      <span class="pill">{product.lineLabel}</span>
      <span class="product-card__weight">{product.weightLabel}</span>
    </div>

    <h3>
      <a href={`/katalog/${product.slug}/`}>{product.title}</a>
    </h3>
    <p class="product-card__subtitle">{product.subtitle}</p>
    <p class="product-card__summary">{product.summary}</p>

    {showHighlights && (
      <ul class="highlight-list highlight-list--compact" aria-label="Ключевые характеристики">
        {product.highlights.slice(0, 3).map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    )}

    <ul class="tag-list" aria-label="Профиль вкуса">
      {product.flavorKeys.map((key) => (
        <li>{flavorLabels[key]}</li>
      ))}
    </ul>

    <div class="button-group button-group--stack">
      <a class="button button--ghost" href={`/katalog/${product.slug}/`}>
        {primaryLabel}
      </a>
      {showNetworkCta && (
        <a class="button button--text" href="/partneram/">
          Для сетей
        </a>
      )}
    </div>
  </div>
</article>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { brand } from "../data/site";
---

<BaseLayout
  title="Контакты Pastodel"
  description="Контакты Pastodel: форма обратной связи, телефон, email и юридическая информация в формате заглушки."
  canonical="/kontakty/"
>
  <section class="page-intro">
    <div class="container page-intro__inner">
      <p class="eyebrow">Контакты</p>
      <h1>Связаться с Pastodel</h1>
      <p>
        Раздел собран как универсальная контактная точка для покупателей,
        партнеров, прессы и коммерческих запросов. Форму можно подключить к
        CRM-системе или почтовому обработчику без изменения структуры страницы.
      </p>
    </div>
  </section>

  <section class="section section--tight-top">
    <div class="container">
      <SectionHeading
        eyebrow="Контактные каналы"
        title="Телефон, email и операционный адрес"
        text="Пока используются реалистичные заглушки, но блок уже готов к замене на реальные данные без изменения верстки."
      />

      <div class="contacts-grid">
        <article class="contact-card">
          <h3>Телефон</h3>
          <p><a href={`tel:${brand.phone.replace(/[^\d+]/g, "")}`}>{brand.phone}</a></p>
          <p>Пн-Пт, 10:00-18:00 по Москве.</p>
        </article>

        <article class="contact-card">
          <h3>Email</h3>
          <p><a href={`mailto:${brand.email}`}>{brand.email}</a></p>
          <p>Общие вопросы, запросы по продукту и медиа.</p>
        </article>

        <article class="contact-card">
          <h3>B2B</h3>
          <p><a href={`mailto:${brand.partnersEmail}`}>{brand.partnersEmail}</a></p>
          <p>Для сетей, дистрибьюторов, доставки и ресторанного канала.</p>
        </article>

        <article class="contact-card">
          <h3>Адрес</h3>
          <p>{brand.address}</p>
          <p>Демо-блок для юридического и операционного адреса.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-grid">
      <form class="form-card" action="#" method="post">
        <SectionHeading
          eyebrow="Форма"
          title="Напишите нам"
          text="Статическая форма для дальнейшего подключения к нужному обработчику."
        />

        <div class="form-grid">
          <div class="field">
            <label for="contact-name">Имя</label>
            <input id="contact-name" name="name" type="text" placeholder="Как к вам обращаться" />
          </div>

          <div class="field">
            <label for="contact-email">Email</label>
            <input id="contact-email" name="email" type="email" placeholder="name@example.ru" />
          </div>

          <div class="field">
            <label for="contact-phone">Телефон</label>
            <input id="contact-phone" name="phone" type="tel" placeholder="+7 (___) ___-__-__" />
          </div>

          <div class="field">
            <label for="contact-topic">Тема</label>
            <select id="contact-topic" name="topic">
              <option>Покупка</option>
              <option>Партнерство</option>
              <option>Пресса и медиа</option>
              <option>Другое</option>
            </select>
          </div>

          <div class="field field--full">
            <label for="contact-message">Сообщение</label>
            <textarea
              id="contact-message"
              name="message"
              placeholder="Опишите вопрос или формат сотрудничества."
            ></textarea>
          </div>
        </div>

        <p class="form-note">
          Демо-режим: кнопка не отправляет данные без подключения обработчика.
        </p>

        <div class="button-group">
          <button class="button" type="submit">Отправить сообщение</button>
        </div>
      </form>

      <div class="legal-grid">
        <article class="legal-card">
          <h3>Юридический блок</h3>
          <ul>
            <li>{brand.legalName}</li>
            <li>ИНН {brand.inn}</li>
            <li>ОГРН {brand.ogrn}</li>
          </ul>
        </article>

        <article class="legal-card">
          <h3>Документы</h3>
          <ul>
            <li>Карточка компании — заглушка</li>
            <li>Декларации и спецификации — заглушка</li>
            <li>Материалы для партнеров — по запросу</li>
          </ul>
        </article>

        <article class="legal-card">
          <h3>Дополнительно</h3>
          <ul>
            <li>Контакт для закупок: {brand.partnersEmail}</li>
            <li>Контакт для общих вопросов: {brand.email}</li>
            <li>Сайт готов к статическому размещению на Nginx</li>
          </ul>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>

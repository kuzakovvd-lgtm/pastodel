---
import BaseLayout from "../layouts/BaseLayout.astro";

const requestRoutes = [
  {
    title: "Торговые сети и дистрибьюторы",
    text: "Для запуска линейки, запроса условий, материалов и обсуждения ассортимента используйте раздел «Для сетей» и форму на этой странице.",
    href: "/partneram/",
    cta: "Для сетей",
  },
  {
    title: "Покупатели",
    text: "Если вы ищете конкретный вкус или хотите уточнить сценарий покупки, начните с каталога и раздела «Где купить», а затем отправьте запрос.",
    href: "/gde-kupit/",
    cta: "Где купить",
  },
  {
    title: "Общие и корпоративные запросы",
    text: "Если вопрос не относится напрямую к покупке или запуску, используйте общую форму.",
    href: "/kontakty/",
    cta: "Написать нам",
  },
];

const contactScenarios = [
  {
    title: "Для запуска линейки",
    text: "Если вы представляете сеть, дистрибьютора или закупочную команду, используйте B2B-маршрут и укажите, какие SKU интересны для первого обсуждения.",
  },
  {
    title: "Для вопроса по продукту",
    text: "Если вас интересует конкретный вкус, состав или сценарий приготовления, сначала откройте карточку SKU, а затем отправьте запрос через форму.",
  },
  {
    title: "Для общего обращения",
    text: "Если вопрос не связан с конкретным SKU, используйте форму как единую точку входа.",
  },
];
---

<BaseLayout
  title="Контакты Pastodel"
  description="Контакты Pastodel: единая точка входа для покупателей, торговых сетей и общих запросов."
  canonical="/kontakty/"
>
  <section class="page-intro">
    <div class="container page-intro__inner">
      <p class="eyebrow">Контакты</p>
      <h1>Связаться с Pastodel</h1>
      <p>Выберите подходящий маршрут обращения и оставьте запрос через форму.</p>
      <div class="button-group">
        <a class="button" href="/partneram/">Для сетей</a>
        <a class="button button--secondary" href="/katalog/">Каталог</a>
        <a class="button button--ghost" href="/gde-kupit/">Где купить</a>
      </div>
    </div>
  </section>

  <section class="section section--tight-top">
    <div class="container">
      <div class="pd-section-head">
        <p class="pd-eyebrow">Сценарии обращения</p>
        <h2>Карточки маршрутов обращения</h2>
      </div>
      <div class="pd-grid pd-grid--3">
        {requestRoutes.map((item) => (
          <article class="pd-channel-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
            <div class="button-group button-group--spaced">
              <a class="pd-button pd-button--ghost" href={item.href}>{item.cta}</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="pd-section-head">
        <p class="pd-eyebrow">Что указать в запросе</p>
        <h2>Какие обращения страница поддерживает уже сейчас</h2>
      </div>
      <div class="pd-grid pd-grid--3">
        {contactScenarios.map((item) => (
          <article class="pd-feature-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container pd-form-shell">
      <form class="form-card" data-validated-form novalidate>
        <div class="pd-section-head">
          <p class="pd-eyebrow">Форма запроса</p>
          <h2>Напишите нам через форму</h2>
          <p class="pd-lead">Укажите тему обращения, компанию или канал и удобный способ связи.</p>
        </div>

        <div class="form-grid">
          <div class="field">
            <label for="contact-name">Имя</label>
            <input id="contact-name" name="name" type="text" placeholder="Как к вам обращаться" data-required-field />
            <p class="pd-form-error" data-error-for="name"></p>
          </div>
          <div class="field">
            <label for="contact-company">Компания или канал</label>
            <input id="contact-company" name="company" type="text" placeholder="Сеть, дистрибьютор, покупатель, медиа" data-required-field />
            <p class="pd-form-error" data-error-for="company"></p>
          </div>
          <div class="field">
            <label for="contact-topic">Тема обращения</label>
            <select id="contact-topic" name="topic" data-required-field>
              <option value="">Выберите тему обращения</option>
              <option>Запуск в сети / B2B</option>
              <option>Вопрос по конкретному SKU</option>
              <option>Уточнение наличия</option>
              <option>Общий запрос</option>
            </select>
            <p class="pd-form-error" data-error-for="topic"></p>
          </div>
          <div class="field">
            <label for="contact-reply">Как с вами связаться</label>
            <input id="contact-reply" name="reply" type="text" placeholder="Email, телефон или удобный способ ответа" data-required-field />
            <p class="pd-form-error" data-error-for="reply"></p>
          </div>
          <div class="field">
            <label for="contact-email">Email</label>
            <input id="contact-email" name="email" type="email" placeholder="name@company.ru" data-required-field />
            <p class="pd-form-error" data-error-for="email"></p>
          </div>
          <div class="field field--full">
            <label for="contact-message">Сообщение</label>
            <textarea id="contact-message" name="message" placeholder="Опишите, какой продукт, канал или тип сотрудничества вас интересует." data-required-field></textarea>
            <p class="pd-form-error" data-error-for="message"></p>
          </div>
        </div>

        <label class="pd-checkbox">
          <input type="checkbox" name="privacy" required />
          <span>Я согласен с политикой конфиденциальности и обработкой персональных данных.</span>
        </label>
        <p class="pd-form-error" data-error-for="privacy"></p>

        <div class="button-group">
          <button class="button" type="submit">Отправить сообщение</button>
        </div>
        <p class="pd-form-note">Форма работает как интерфейс для будущего подключения обработчика.</p>
        <p class="pd-form-success" data-form-success hidden>Спасибо. Сообщение принято.</p>
      </form>
    </div>
  </section>

  <section class="pd-section pd-direct-contacts pd-is-hidden">
    <!-- заполнить после передачи подтверждённых контактов -->
  </section>
</BaseLayout>

---
import ProductCard from "../components/ProductCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { products } from "../data/products";

const introCards = [
  {
    title: "Федеральные и региональные сети",
    text: "Для категорий, где нужен понятный продукт с быстрым сценарием покупки и без сложной полочной коммуникации.",
    example: "Стартовый набор: Альфредо с курицей, Карбонара, Ветчина с грибами.",
    cta: "Обсудить запуск",
  },
  {
    title: "Дистрибьюторы и оптовые партнёры",
    text: "Для каналов, где важны ясная продуктовая логика, аккуратный ассортимент и готовые материалы для первого обсуждения.",
    example: "Базовый набор: Альфредо с курицей, Карбонара, Паста с фрикадельками.",
    cta: "Запросить материалы",
  },
  {
    title: "Пилотные запуски и тестовые вводы",
    text: "Для сценариев, где запуск начинается с ограниченного набора SKU и последующей оценки спроса.",
    example: "Тестовый набор: Карбонара, Паста с фрикадельками.",
    cta: "Запросить условия",
  },
];

const matrixCards = [
  {
    title: "Понятные вкусы",
    text: "Линейка построена вокруг узнаваемых вкусов без сложной полочной коммуникации.",
  },
  {
    title: "Формат 400 г",
    text: "На сайте и в карточках SKU используется один базовый формат — 400 г.",
  },
  {
    title: "Быстрый сценарий приготовления",
    text: "В карточках SKU уже вынесен способ приготовления для домашнего разогрева.",
  },
  {
    title: "Маршрут к материалам уже собран",
    text: "Для первого разговора уже есть каталог, B2B-раздел, корпоративный раздел и форма запроса.",
  },
];

const sellInCards = [
  {
    title: "Ассортимент",
    items: [
      "В линейке уже собраны классические и более яркие вкусы.",
      "SKU разведены по ролям: ежедневная классика, семейные хиты, лёгкий выбор.",
      "Каждый вкус можно открыть как отдельную карточку.",
    ],
  },
  {
    title: "Экономика",
    items: [
      "Списания в заморозке в 3–4 раза ниже, чем в охлаждённой кулинарии.",
      "Формат линейки позволяет начинать с ограниченного набора SKU.",
      "Пилотный запуск можно обсуждать через отдельную форму.",
    ],
  },
  {
    title: "Удобство для полки",
    items: [
      "Продукт подаётся как готовое блюдо для повседневного спроса.",
      "Карточки SKU уже показывают вкус, формат, хранение и приготовление.",
      "Сайт разведён по маршрутам: продукция, для сетей, о компании, где купить, контакты.",
    ],
  },
];

const assortmentCards = [
  {
    title: "Ежедневная классика",
    text: "Сливочные и привычные вкусы для регулярной покупки без сложного выбора.",
  },
  {
    title: "Семейные хиты",
    text: "Более сытные позиции для сценария домашнего ужина.",
  },
  {
    title: "Лёгкий выбор",
    text: "Более мягкие и овощные вкусы для расширения линейки без перегруза полки.",
  },
];

const formatCards = [
  {
    title: "Формат линейки 400 г",
    text: "Упаковка 400 г уже используется на сайте и в карточках SKU как базовый формат линейки.",
  },
  {
    title: "Понятная роль в категории",
    text: "Продукт подаётся как готовая замороженная паста для повседневного спроса.",
  },
  {
    title: "Детали по запросу",
    text: "Подробные параметры для ввода в сеть и документы должны открываться через отдельный запрос.",
  },
];

const materialCards = [
  {
    title: "Что уже готово для первого контакта",
    items: [
      "Презентация для первого обсуждения",
      "Карточки SKU и продуктовая структура",
      "Контактный маршрут для запроса",
    ],
  },
  {
    title: "Где искать подтверждающие разделы",
    items: [
      "О компании",
      "Продукция и карточки SKU",
      "Контакты",
      "Отдельный маршрут для запроса документов",
    ],
  },
];

const featuredB2BProducts = ["alfredo-kuritsa", "karbonara", "vetchina-griby-slivochny-sous", "pasta-frikadelki-tomatny-sous"]
  .map((slug) => products.find((product) => product.slug === slug))
  .filter(Boolean);
---

<BaseLayout
  title="Для сетей Pastodel — B2B-раздел для байеров и дистрибьюторов"
  description="Pastodel для торговых сетей и дистрибьюторов: структура ассортимента, логика линейки, sell-in-аргументы и старт переговоров."
  canonical="/partneram/"
>
  <section class="page-intro">
    <div class="container page-intro__inner">
      <p class="eyebrow">Для сетей</p>
      <h1>Готовые пасты Pastodel для сетей и дистрибьюторов</h1>
      <p>В этом разделе собраны материалы для первого разговора: структура ассортимента, логика полки, карточки SKU и форма запроса.</p>
      <ul class="pd-badge-list">
        <li class="pd-badge">400 г</li>
        <li class="pd-badge">SKU-каталог</li>
        <li class="pd-badge">Форма запроса</li>
        <li class="pd-badge">Материалы для первого контакта</li>
      </ul>
    </div>
  </section>

  <section class="section section--tight-top">
    <div class="container">
      <div class="pd-section-head">
        <p class="pd-eyebrow">Кому подходит</p>
        <h2>С кем удобнее всего начинать обсуждение</h2>
      </div>
      <div class="pd-grid pd-grid--3">
        {introCards.map((item) => (
          <article class="pd-channel-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
            <p class="pd-form-note">{item.example}</p>
            <div class="button-group button-group--spaced">
              <a class="pd-button pd-button--ghost" href="/kontakty/">{item.cta}</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="pd-section-head">
        <p class="pd-eyebrow">Для сети</p>
        <h2>Чем Pastodel удобен для ввода в матрицу</h2>
      </div>
      <div class="pd-grid pd-grid--4">
        {matrixCards.map((item) => (
          <article class="pd-feature-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="pd-section-head">
        <p class="pd-eyebrow">Sell-in</p>
        <h2>Основные аргументы для первого разговора</h2>
      </div>
      <div class="pd-grid pd-grid--3">
        {sellInCards.map((item) => (
          <article class="pd-sellin-card">
            <h3>{item.title}</h3>
            <ul class="detail-list detail-list--spaced">
              {item.items.map((point) => (
                <li>{point}</li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="pd-section-head">
        <p class="pd-eyebrow">Ассортимент</p>
        <h2>Какие SKU уже собраны в линейке</h2>
      </div>
      <div class="pd-grid pd-grid--3">
        {assortmentCards.map((item) => (
          <article class="pd-feature-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
      <div class="products-grid products-grid--spaced">
        {featuredB2BProducts.map((product) => (
          <ProductCard product={product} primaryLabel="Смотреть SKU" />
        ))}
      </div>
      <div class="button-group button-group--spaced">
        <a class="button" href="/katalog/">Смотреть весь ассортимент</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="pd-section-head">
        <p class="pd-eyebrow">Формат и категория</p>
        <h2>Формат и категория</h2>
      </div>
      <div class="pd-grid pd-grid--3">
        {formatCards.map((item) => (
          <article class="pd-feature-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container pd-grid pd-grid--2">
      {materialCards.map((item) => (
        <article class="pd-material-card">
          <h3>{item.title}</h3>
          <ul class="detail-list detail-list--spaced">
            {item.items.map((point) => (
              <li>{point}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="container pd-form-shell">
      <form class="form-card" data-validated-form novalidate>
        <div class="pd-section-head">
          <p class="pd-eyebrow">Форма запроса</p>
          <h2>Оставьте B2B-запрос по линейке</h2>
        </div>

        <div class="form-grid">
          <div class="field">
            <label for="partner-name">Имя</label>
            <input id="partner-name" name="name" type="text" placeholder="Как к вам обращаться" data-required-field />
            <p class="pd-form-error" data-error-for="name"></p>
          </div>
          <div class="field">
            <label for="partner-company">Компания</label>
            <input id="partner-company" name="company" type="text" placeholder="Название сети или партнёра" data-required-field />
            <p class="pd-form-error" data-error-for="company"></p>
          </div>
          <div class="field">
            <label for="partner-email">Email</label>
            <input id="partner-email" name="email" type="email" placeholder="name@company.ru" data-required-field />
            <p class="pd-form-error" data-error-for="email"></p>
          </div>
          <div class="field">
            <label for="partner-role">Роль</label>
            <select id="partner-role" name="role" data-required-field>
              <option value="">Выберите сценарий</option>
              <option>Байер / категория</option>
              <option>Дистрибьютор</option>
              <option>Оптовый партнёр</option>
              <option>Пилотный запуск</option>
            </select>
            <p class="pd-form-error" data-error-for="role"></p>
          </div>
          <div class="field">
            <label for="partner-sku-count">Количество SKU для теста</label>
            <select id="partner-sku-count" name="sku_count">
              <option value="2">2 SKU</option>
              <option value="3">3 SKU</option>
              <option value="4">4 SKU</option>
              <option value="5plus">5+ SKU</option>
            </select>
          </div>
          <div class="field field--full">
            <label for="partner-message">Комментарий</label>
            <textarea id="partner-message" name="message" placeholder="Какие SKU или формат канала вас интересуют?" data-required-field></textarea>
            <p class="pd-form-error" data-error-for="message"></p>
          </div>
        </div>

        <label class="pd-checkbox">
          <input type="checkbox" name="privacy" required />
          <span>Я согласен с политикой конфиденциальности и обработкой персональных данных.</span>
        </label>
        <p class="pd-form-error" data-error-for="privacy"></p>
        <div class="button-group">
          <button class="button" type="submit">Отправить заявку</button>
        </div>
        <p class="pd-form-note">Сейчас форма работает как интерфейс для будущего подключения обработчика.</p>
        <p class="pd-form-success" data-form-success hidden>Спасибо. Форма заполнена корректно.</p>
      </form>
    </div>
  </section>
</BaseLayout>

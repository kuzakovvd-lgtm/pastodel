---
import ProductCard from "../../components/ProductCard.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { flavorFilters, lineFilters, products } from "../../data/products";

const catalogOrder = [
  "alfredo-kuritsa",
  "karbonara",
  "mak-end-chiz",
  "vetchina-griby-slivochny-sous",
  "pasta-frikadelki-tomatny-sous",
  "chetyre-syra",
  "kuritsa-pesto-vyalenye-tomaty",
  "primavera",
  "rizotto-rizi-bizi-pesto-zeleny-goroshek",
  "rizotto-griby-slivochny-sous",
  "paelya-kuritsa-ovoshchi",
];

const orderedProducts = catalogOrder
  .map((slug) => products.find((product) => product.slug === slug))
  .filter(Boolean);

const lineGuide = [
  {
    key: "casa",
    title: "Ежедневная классика",
    text: "Максимально понятные вкусы для повседневного выбора: сливочные и домашние сочетания, с которых удобно начинать знакомство с линейкой.",
  },
  {
    key: "chef",
    title: "Сытные блюда",
    text: "Более насыщенные позиции для расширения полки: выразительные вкусы, мясные акценты и блюда, которые считываются как полноценный ужин.",
  },
  {
    key: "verde",
    title: "Овощные и легкие вкусы",
    text: "Позиции для более легкого сценария выбора. Эти SKU помогают показать широту линейки без ухода в нишевую гастрономию.",
  },
].map((item) => ({
  ...item,
  count: products.filter((product) => product.line === item.key).length,
}));
---

<BaseLayout
  title="Продукция Pastodel — ассортимент готовых замороженных блюд"
  description="Ассортимент Pastodel: SKU готовых замороженных блюд с понятной структурой линейки, переходами в карточки товаров и отдельным маршрутом для торговых сетей."
  canonical="/katalog/"
>
  <section class="page-intro">
    <div class="container page-intro__inner">
      <p class="eyebrow">Продукция</p>
      <h1>Продукция Pastodel</h1>
      <p>
        Раздел собран как витрина ассортимента производителя: здесь можно быстро
        понять, какие SKU есть в линейке, чем отличаются вкусы и куда перейти
        за деталями по каждому продукту. Каталог помогает и обычному посетителю,
        и байеру, который оценивает структуру линейки для запуска.
      </p>
      <div class="button-group">
        <a class="button" href="/partneram/">Посмотреть линейку для сетей</a>
        <a class="button button--secondary" href="/gde-kupit/">Где купить</a>
      </div>
    </div>
  </section>

  <section class="section section--tight-top">
    <div class="container">
      <SectionHeading
        eyebrow="Логика линейки"
        title="Как устроен ассортимент Pastodel"
        text="Вместо длинного списка без структуры каталог сначала показывает, как читать линейку: с чего начать, где искать более сытные позиции и какие SKU расширяют выбор."
      />

      <div class="cards-grid">
        {lineGuide.map((item) => (
          <article class="feature-card catalog-guide-card">
            <div class="product-card__meta">
              <span class="pill">{item.title}</span>
              <span class="product-card__weight">{item.count} SKU</span>
            </div>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--tight-top">
    <div class="container">
      <SectionHeading
        eyebrow="Фильтры и выбор"
        title="Соберите витрину по логике линейки и вкусовому профилю"
        text="Фильтр помогает быстрее увидеть структуру ассортимента. Если JavaScript отключен, каталог все равно остается понятным и показывает весь набор SKU целиком."
      />

      <div class="catalog-toolbar">
        <div class="filter-stack">
          <div class="filter-row">
            <strong>Линейка</strong>
            <div class="filter-chips" data-filter-group="line">
              {lineFilters.map((filter, index) => (
                <button
                  class:list={["filter-chip", index === 0 && "is-active"]}
                  type="button"
                  data-filter-button
                  data-group="line"
                  data-value={filter.key}
                  aria-pressed={index === 0 ? "true" : "false"}
                >
                  {filter.label}
                </button>
              ))}
            </div>
          </div>

          <div class="filter-row">
            <strong>Вкус</strong>
            <div class="filter-chips" data-filter-group="flavor">
              {flavorFilters.map((filter, index) => (
                <button
                  class:list={["filter-chip", index === 0 && "is-active"]}
                  type="button"
                  data-filter-button
                  data-group="flavor"
                  data-value={filter.key}
                  aria-pressed={index === 0 ? "true" : "false"}
                >
                  {filter.label}
                </button>
              ))}
            </div>
          </div>
        </div>

        <p class="form-note">
          В каталоге {orderedProducts.length} SKU. Открывайте карточки товаров,
          если нужно посмотреть вкус, состав, приготовление и упаковочный формат
          конкретной позиции.
        </p>
      </div>

      <div class="products-grid" id="catalog-grid">
        {orderedProducts.map((product, index) => (
          <ProductCard
            product={product}
            showHighlights={true}
            showNetworkCta={true}
            primaryLabel="Открыть карточку товара"
            imageLoading={index < 3 ? "eager" : "lazy"}
            imageFetchPriority={index === 0 ? "high" : "auto"}
          />
        ))}
      </div>

      <p class="catalog-empty" data-empty hidden>
        По выбранным параметрам ничего не найдено. Сбросьте фильтры и
        посмотрите все вкусы.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="partner-band surface-card">
        <p class="eyebrow">Для сетей</p>
        <h2>Если ассортимент интересен для запуска, переходите в отдельный B2B-раздел</h2>
        <p>
          Каталог показывает линейку и помогает сравнить SKU, а раздел «Для
          сетей» продолжает сценарий для байера: объясняет sell-in-логику,
          формат запуска и доступные материалы для первого обсуждения.
        </p>
        <div class="button-group">
          <a class="button" href="/partneram/">Перейти в раздел для сетей</a>
          <a class="button button--ghost" href="/docs/pastodel-b2b-placeholder.pdf" download>
            Скачать PDF
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="cta-strip surface-card">
        <p class="eyebrow">Следующий шаг</p>
        <h2>Каталог ведет в два маршрута: детальный просмотр SKU и диалог с производителем</h2>
        <p>
          Если вы выбираете вкус и формат для себя, переходите в карточки
          продуктов и раздел «Где купить». Если вы оцениваете линейку для сети,
          используйте раздел «Для сетей» и контакты.
        </p>
        <div class="button-group">
          <a class="button" href="/gde-kupit/">Где купить</a>
          <a class="button button--secondary" href="/partneram/">Для сетей</a>
          <a class="button button--ghost" href="/kontakty/">Связаться</a>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    const state = { line: "all", flavor: "all" };
    const filterButtons = Array.from(document.querySelectorAll("[data-filter-button]"));
    const cards = Array.from(document.querySelectorAll("[data-card]"));
    const emptyState = document.querySelector("[data-empty]");

    const applyFilters = () => {
      let visibleCount = 0;

      cards.forEach((card) => {
        const line = card.dataset.line || "";
        const flavors = (card.dataset.flavors || "").split(" ").filter(Boolean);
        const lineMatch = state.line === "all" || line === state.line;
        const flavorMatch =
          state.flavor === "all" || flavors.includes(state.flavor);
        const shouldShow = lineMatch && flavorMatch;

        card.hidden = !shouldShow;
        if (shouldShow) visibleCount += 1;
      });

      if (emptyState) {
        emptyState.hidden = visibleCount !== 0;
      }
    };

    filterButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const group = button.dataset.group;
        const value = button.dataset.value || "all";
        if (!group) return;

        state[group] = value;

        filterButtons
          .filter((candidate) => candidate.dataset.group === group)
          .forEach((candidate) => {
            const active = candidate === button;
            candidate.classList.toggle("is-active", active);
            candidate.setAttribute("aria-pressed", String(active));
          });

        applyFilters();
      });
    });

    applyFilters();
  </script>
</BaseLayout>

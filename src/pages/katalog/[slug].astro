---
import ProductCard from "../../components/ProductCard.astro";
import ProductImage from "../../components/ProductImage.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { flavorLabels, products, type Product } from "../../data/products";
import { brand } from "../../data/site";

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props as { product: Product };

const relatedProducts = products
  .filter((item) => item.slug !== product.slug)
  .sort((a, b) => {
    const aScore =
      (a.line === product.line ? 2 : 0) +
      a.flavorKeys.filter((key) => product.flavorKeys.includes(key)).length;
    const bScore =
      (b.line === product.line ? 2 : 0) +
      b.flavorKeys.filter((key) => product.flavorKeys.includes(key)).length;

    return bScore - aScore;
  })
  .slice(0, 3);

const siteUrl = Astro.site?.toString() ?? brand.siteUrl;

const productSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Главная", item: siteUrl },
        { "@type": "ListItem", position: 2, name: "Продукция", item: `${siteUrl}katalog/` },
        { "@type": "ListItem", position: 3, name: product.title, item: `${siteUrl}katalog/${product.slug}/` },
      ],
    },
    {
      "@type": "Product",
      name: product.title,
  description: product.description,
  sku: product.sku,
  category: `Замороженная готовая паста — ${product.lineLabel}`,
  image: [new URL(product.image, Astro.site ?? brand.siteUrl).toString()],
  brand: {
    "@type": "Brand",
    name: brand.name,
  },
  countryOfOrigin: "RU",
  weight: {
    "@type": "QuantitativeValue",
    value: product.weightGrams,
    unitCode: "GRM",
  },
  nutrition: {
    "@type": "NutritionInformation",
    calories: `${product.nutrition.calories} kcal`,
    proteinContent: `${product.nutrition.protein} g`,
    fatContent: `${product.nutrition.fat} g`,
    carbohydrateContent: `${product.nutrition.carbs} g`,
  },
  additionalProperty: [
    {
      "@type": "PropertyValue",
      name: "Условия хранения",
      value: product.storage.join(" "),
    },
    {
      "@type": "PropertyValue",
      name: "Способ приготовления",
      value: product.cooking.join(" "),
    },
  ],
    },
  ],
};
---

<BaseLayout
  title={`${product.title} ${product.weightLabel} — ${brand.name}`}
  description={product.summary}
  canonical={`/katalog/${product.slug}/`}
  image={product.image}
  ogType="article"
  schema={productSchema}
>
  <section class="page-intro">
    <div class="container">
      <ol class="breadcrumbs">
        <li><a href="/">Главная</a></li>
        <li><a href="/katalog/">Продукция</a></li>
        <li>{product.title}</li>
      </ol>

      <div class="product-layout">
        <div class="product-media product-detail-card">
          <ProductImage
            src={product.image}
            alt={product.title}
            width="960"
            height="960"
            loading="eager"
            variant="detail"
          />
        </div>

        <article class="product-summary">
          <p class="eyebrow">{product.lineLabel}</p>
          <h1>{product.title}</h1>
          <p class="lead">{product.subtitle}</p>
          <p class="product-summary__text">{product.summary}</p>
          <p>{product.description}</p>

          <ul class="pd-product-benefits">
            <li>Формат упаковки вынесен в карточку товара.</li>
            <li>Состав собран в отдельном блоке.</li>
            <li>Способ приготовления вынесен ниже на странице.</li>
            <li>Маршрут «Где купить» и форма вопроса доступны отдельно.</li>
          </ul>

          <ul class="highlight-list" aria-label="Преимущества продукта">
            {product.highlights.map((item) => (
              <li>{item}</li>
            ))}
          </ul>

          <ul class="tag-list" aria-label="Профиль вкуса">
            {product.flavorKeys.map((key) => (
              <li>{flavorLabels[key]}</li>
            ))}
          </ul>

          <div class="metric-grid">
            <div class="metric-card">
              <span>Вес</span>
              <strong>{product.weightLabel}</strong>
            </div>
            <div class="metric-card">
              <span>SKU</span>
              <strong>{product.sku}</strong>
            </div>
            <div class="metric-card">
              <span>Упаковка</span>
              <strong>{product.packageType}</strong>
            </div>
            <div class="metric-card">
              <span>Линейка</span>
              <strong>{product.lineLabel}</strong>
            </div>
          </div>

          <div class="button-group">
            <a class="button" href="/gde-kupit/">Где купить</a>
            <a class="button button--secondary" href="/partneram/">Для сетей</a>
            <a class="button button--ghost" href="/katalog/">Весь каталог</a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="section section--tight-top">
    <div class="container product-details-grid">
      <article class="product-detail-card">
        <h2>Ключевые параметры</h2>
        <ul class="detail-list">
          <li>{product.weightLabel} в упаковке</li>
          <li>{product.packageType}</li>
          <li>{product.lineLabel}</li>
          <li>SKU: {product.sku}</li>
        </ul>
      </article>
    </div>
  </section>

  <section class="section section--tight-top">
    <div class="container product-details-grid">
      <article class="product-detail-card">
        <h2>Состав</h2>
        <ul class="detail-list">
          {product.ingredients.map((ingredient) => (
            <li>{ingredient}</li>
          ))}
        </ul>
      </article>

      <article class="product-detail-card">
        <h2>Пищевая ценность на 100 г</h2>
        <table class="nutrition-table">
          <tbody>
            <tr>
              <th scope="row">Энергетическая ценность</th>
              <td>{product.nutrition.calories} ккал</td>
            </tr>
            <tr>
              <th scope="row">Белки</th>
              <td>{product.nutrition.protein} г</td>
            </tr>
            <tr>
              <th scope="row">Жиры</th>
              <td>{product.nutrition.fat} г</td>
            </tr>
            <tr>
              <th scope="row">Углеводы</th>
              <td>{product.nutrition.carbs} г</td>
            </tr>
          </tbody>
        </table>
      </article>

      <article class="product-detail-card">
        <h2>Способ приготовления</h2>
        <p class="meta-kicker meta-kicker--spaced">
          Подходит для сценария быстрого домашнего разогрева без сложной подготовки.
        </p>
        <ul class="detail-list">
          {product.cooking.map((step) => (
            <li>{step}</li>
          ))}
        </ul>
      </article>

      <article class="product-detail-card">
        <h2>Хранение и формат</h2>
        <ul class="detail-list">
          {product.storage.map((rule) => (
            <li>{rule}</li>
          ))}
        </ul>
        <ul class="detail-list detail-list--spaced">
          <li>{product.packageType}</li>
          <li>{product.weightLabel}</li>
        </ul>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="pd-section-head">
        <p class="pd-eyebrow">FAQ</p>
        <h2>FAQ</h2>
      </div>
      <div class="pd-faq" data-accordion>
        <div class="pd-faq__item">
          <button class="pd-faq__button" type="button" aria-expanded="false">Где смотреть состав?</button>
          <div class="pd-faq__panel">
            <p>Состав вынесен в отдельный блок карточки товара.</p>
          </div>
        </div>
        <div class="pd-faq__item">
          <button class="pd-faq__button" type="button" aria-expanded="false">Как приготовить продукт дома?</button>
          <div class="pd-faq__panel">
            <p>Способ приготовления вынесен в отдельный блок карточки товара.</p>
          </div>
        </div>
        <div class="pd-faq__item">
          <button class="pd-faq__button" type="button" aria-expanded="false">Как хранить продукт?</button>
          <div class="pd-faq__panel">
            <p>Условия хранения вынесены в отдельный блок карточки товара.</p>
          </div>
        </div>
        <div class="pd-faq__item">
          <button class="pd-faq__button" type="button" aria-expanded="false">Где уточнить наличие?</button>
          <div class="pd-faq__panel">
            <p>Перейдите в раздел «Где купить» или оставьте запрос через страницу «Контакты».</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="pd-product-cta">
        <a class="pd-button" href="/gde-kupit/">Где купить</a>
        <a class="pd-button pd-button--ghost" href="/kontakty/">Задать вопрос по продукту</a>
      </div>
    </div>
  </section>

  <section class="section section--flush-top">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Еще в каталоге</p>
        <h2>Другие вкусы Pastodel</h2>
        <p>
          Если нужен другой вкусовой сценарий, сравните соседние SKU из той же
          линейки или с близким профилем.
        </p>
      </div>

      <div class="products-grid">
        {relatedProducts.map((item) => (
          <ProductCard
            product={item}
            showHighlights={true}
            primaryLabel="Открыть SKU"
          />
        ))}
      </div>

      <div class="button-group button-group--spaced">
        <a class="button button--ghost" href="/katalog/">Вернуться в каталог</a>
      </div>
    </div>
  </section>
</BaseLayout>

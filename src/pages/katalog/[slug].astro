---
import ProductCard from "../../components/ProductCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { products, type Product } from "../../data/products";
import { brand } from "../../data/site";

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props as { product: Product };

const relatedProducts = products
  .filter((item) => item.slug !== product.slug)
  .slice(0, 3);

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: product.title,
  description: product.description,
  sku: product.sku,
  category: `Замороженная готовая паста — ${product.lineLabel}`,
  image: [new URL(product.image, Astro.site ?? brand.siteUrl).toString()],
  brand: {
    "@type": "Brand",
    name: brand.name,
  },
  countryOfOrigin: "RU",
  weight: {
    "@type": "QuantitativeValue",
    value: product.weightGrams,
    unitCode: "GRM",
  },
  nutrition: {
    "@type": "NutritionInformation",
    calories: `${product.nutrition.calories} kcal`,
    proteinContent: `${product.nutrition.protein} g`,
    fatContent: `${product.nutrition.fat} g`,
    carbohydrateContent: `${product.nutrition.carbs} g`,
  },
  additionalProperty: [
    {
      "@type": "PropertyValue",
      name: "Условия хранения",
      value: product.storage.join(" "),
    },
    {
      "@type": "PropertyValue",
      name: "Способ приготовления",
      value: product.cooking.join(" "),
    },
  ],
};
---

<BaseLayout
  title={`${product.title} — ${brand.name}`}
  description={product.summary}
  canonical={`/katalog/${product.slug}/`}
  image={product.image}
  ogType="article"
  schema={productSchema}
>
  <section class="page-intro">
    <div class="container">
      <ol class="breadcrumbs">
        <li><a href="/">Главная</a></li>
        <li><a href="/katalog/">Каталог</a></li>
        <li>{product.title}</li>
      </ol>

      <div class="product-layout">
        <div class="product-media product-detail-card">
          <img
            src={product.image}
            alt={product.title}
            width="960"
            height="720"
          />
        </div>

        <article class="product-summary">
          <p class="eyebrow">{product.lineLabel}</p>
          <h1>{product.title}</h1>
          <p class="lead">{product.subtitle}</p>
          <p>{product.description}</p>

          <ul class="highlight-list" aria-label="Преимущества продукта">
            {product.highlights.map((item) => (
              <li>{item}</li>
            ))}
          </ul>

          <div class="metric-grid">
            <div class="metric-card">
              <span>Вес</span>
              <strong>{product.weightLabel}</strong>
            </div>
            <div class="metric-card">
              <span>SKU</span>
              <strong>{product.sku}</strong>
            </div>
            <div class="metric-card">
              <span>Упаковка</span>
              <strong>{product.packageType}</strong>
            </div>
            <div class="metric-card">
              <span>Канал</span>
              <strong>B2C и B2B</strong>
            </div>
          </div>

          <div class="button-group">
            <a class="button" href="/gde-kupit/">Где купить</a>
            <a class="button button--ghost" href="/partneram/">Стать партнером</a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="section section--tight-top">
    <div class="container product-details-grid">
      <article class="product-detail-card">
        <h2>Описание и состав</h2>
        <p class="meta-kicker meta-kicker--spaced">{product.summary}</p>
        <ul class="detail-list">
          {product.ingredients.map((ingredient) => (
            <li>{ingredient}</li>
          ))}
        </ul>
      </article>

      <article class="product-detail-card">
        <h2>Пищевая ценность на 100 г</h2>
        <table class="nutrition-table">
          <tbody>
            <tr>
              <th scope="row">Энергетическая ценность</th>
              <td>{product.nutrition.calories} ккал</td>
            </tr>
            <tr>
              <th scope="row">Белки</th>
              <td>{product.nutrition.protein} г</td>
            </tr>
            <tr>
              <th scope="row">Жиры</th>
              <td>{product.nutrition.fat} г</td>
            </tr>
            <tr>
              <th scope="row">Углеводы</th>
              <td>{product.nutrition.carbs} г</td>
            </tr>
          </tbody>
        </table>
      </article>

      <article class="product-detail-card">
        <h2>Способ приготовления</h2>
        <ul class="detail-list">
          {product.cooking.map((step) => (
            <li>{step}</li>
          ))}
        </ul>
      </article>

      <article class="product-detail-card">
        <h2>Условия хранения</h2>
        <ul class="detail-list">
          {product.storage.map((rule) => (
            <li>{rule}</li>
          ))}
        </ul>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="cta-strip surface-card">
        <p class="eyebrow">Покупка и поставки</p>
        <h2>Этот SKU можно включить в розничную матрицу, доставку или пилотный запуск</h2>
        <p>
          Для B2C-продаж продукт ведет на раздел «Где купить». Для B2B-запросов
          доступен партнерский раздел с формой заявки и коммерческими вводными.
        </p>
        <div class="button-group">
          <a class="button" href="/gde-kupit/">Где купить</a>
          <a class="button button--secondary" href="/partneram/">Партнерский запрос</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--flush-top">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Еще в каталоге</p>
        <h2>Другие вкусы Pastodel</h2>
      </div>

      <div class="products-grid">
        {relatedProducts.map((item) => (
          <ProductCard product={item} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

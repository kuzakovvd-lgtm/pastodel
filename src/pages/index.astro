---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroSection from "../components/HeroSection.astro";
import RetailSection from "../components/RetailSection.astro";
import ProductsSection from "../components/ProductsSection.astro";
import { brand } from "../data/site";

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: brand.name,
  url: brand.siteUrl,
  logo: `${brand.siteUrl}/favicon.svg`,
  description: "Готовые замороженные блюда для быстрого и понятного выбора.",
};
---

<BaseLayout
  title="Pastodel — готовые замороженные блюда"
  description="Pastodel — готовые замороженные блюда для быстрого и понятного выбора: линейка продукции для покупателей и понятный маршрут для торговых сетей."
  image="/images/og-card.png"
  schema={organizationSchema}
>
  <HeroSection />
  <RetailSection />
  <ProductsSection />
</BaseLayout>

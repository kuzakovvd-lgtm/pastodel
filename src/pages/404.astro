---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Страница не найдена — Pastodel"
  description="Запрошенная страница Pastodel не найдена."
>
  <section class="section">
    <div class="container">
      <div class="cta-strip surface-card">
        <p class="eyebrow">404</p>
        <h1>Страница не найдена</h1>
        <p>
          Проверьте адрес страницы или вернитесь в каталог Pastodel, чтобы
          продолжить просмотр ассортимента.
        </p>
        <div class="button-group">
          <a class="button" href="/">На главную</a>
          <a class="button button--ghost" href="/katalog/">Перейти в каталог</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

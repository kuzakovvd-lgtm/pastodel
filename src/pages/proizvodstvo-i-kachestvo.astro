---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";

const frozenFormatPoints = [
  {
    title: "Замороженный формат как часть продуктовой логики",
    text: "На сайте Pastodel заморозка подается не как техническая деталь, а как понятный для покупателя и сети формат готового блюда.",
  },
  {
    title: "Понятный сценарий хранения",
    text: "В карточках SKU уже есть базовые правила хранения и обращения с продуктом. Это помогает говорить о качестве через понятные пользовательские действия, а не через формальные обещания.",
  },
  {
    title: "Удобство для полки и дома",
    text: "Сайт описывает продукт через сочетание формата, хранения и быстрого приготовления, что делает категорию понятной и для байера, и для конечного покупателя.",
  },
];

const productApproach = [
  {
    title: "Качество начинается с понятного продукта",
    text: "Pastodel описывает блюда через вкус, состав, приготовление и хранение. Такой подход делает восприятие продукта прозрачным и не перегружает коммуникацию лишней технической терминологией.",
  },
  {
    title: "Приготовление как часть качества",
    text: "Для каждого SKU на сайте уже собран короткий сценарий разогрева. Это важная часть доверия: продукт должен быть не только заметным на полке, но и предсказуемым в использовании.",
  },
  {
    title: "Ассортимент как контролируемая структура",
    text: "Каталог собран вокруг понятных блюд и ролей внутри линейки. Это поддерживает доверие к продукту лучше, чем хаотичный набор SKU без объяснимой логики.",
  },
];

const packagingPoints = [
  {
    title: "Упаковка как носитель понятной информации",
    text: "На упаковке считываются формат блюда, способ приготовления и порционность. Это помогает снижать барьер выбора и делает продукт удобным для повседневного сценария.",
  },
  {
    title: "Сохранность как часть потребительского опыта",
    text: "На сайте акцент сделан на том, чтобы продукт был удобен в хранении, разогреве и подаче. Без подтвержденных технических параметров эта страница не уходит в ложную детализацию.",
  },
  {
    title: "Единая логика линейки",
    text: "Похожая структура упаковки, формата и карточек товаров помогает воспринимать ассортимент как целостную систему, а не как набор разрозненных позиций.",
  },
];

const retailQuality = [
  {
    title: "Понятная коммуникация для сети",
    text: "B2B-контур сайта уже разведен так, чтобы качество и продуктовый подход можно было обсуждать отдельно от коммерческого sell-in-сценария.",
    href: "/partneram/",
    cta: "Перейти в раздел для сетей",
  },
  {
    title: "Отдельный документальный контур",
    text: "Для документов, спецификаций и подтверждающих материалов на сайте уже выделен самостоятельный раздел.",
    href: "/dokumenty/",
    cta: "Открыть документы",
  },
  {
    title: "Прямой контакт для уточнения деталей",
    text: "Если в процессе обсуждения нужны дополнительные материалы или пояснения, следующий шаг — связаться через контакты.",
    href: "/kontakty/",
    cta: "Связаться",
  },
];
---

<BaseLayout
  title="Производство и качество Pastodel"
  description="Pastodel: подход к качеству продукта, замороженному формату, приготовлению, упаковке и связке с B2B- и документальным контуром сайта."
  canonical="/proizvodstvo-i-kachestvo/"
>
  <section class="page-intro">
    <div class="container page-intro__inner">
      <p class="eyebrow">Производство и качество</p>
      <h1>Качество продукта и производственный подход без лишней технической риторики</h1>
      <p>
        Эта страница не притворяется техническим паспортом производства. Ее
        задача — спокойно объяснить, как Pastodel подходит к качеству через
        сам продукт: замороженный формат, удобство хранения, приготовление,
        упаковку и понятный путь к документам и B2B-диалогу.
      </p>
      <div class="button-group">
        <a class="button" href="/dokumenty/">Документы</a>
        <a class="button button--secondary" href="/partneram/">Для сетей</a>
        <a class="button button--ghost" href="/kontakty/">Связаться</a>
      </div>
    </div>
  </section>

  <section class="section section--tight-top">
    <div class="container">
      <SectionHeading
        eyebrow="Замороженный формат"
        title="Что важно в замороженном формате"
        text="Доверие к продукту на этой странице строится не через непроверенные производственные детали, а через понятную логику самого формата."
      />

      <div class="cards-grid">
        {frozenFormatPoints.map((item) => (
          <article class="feature-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-grid">
      <article class="partner-card">
        <p class="eyebrow">Подход к продукту</p>
        <h2>Качество здесь связано с удобством, предсказуемостью и понятной подачей</h2>
        <div class="detail-stack">
          {productApproach.map((item) => (
            <div>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </div>
          ))}
        </div>
      </article>

      <article class="partner-card">
        <p class="eyebrow">Приготовление и хранение</p>
        <h2>Эти темы уже раскрываются на уровне карточек SKU</h2>
        <p>
          В проекте для каждого товара уже заданы блоки приготовления,
          хранения, веса и формата упаковки. Это помогает говорить о качестве
          через конкретный пользовательский опыт, а не через абстрактные
          обещания.
        </p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Упаковка и сохранность"
        title="Как упаковка и подача поддерживают доверие к продукту"
        text="Этот раздел говорит о логике упаковки и сохранности на понятном уровне, не уходя в неподтвержденные технические параметры."
      />

      <div class="feature-grid">
        {packagingPoints.map((item) => (
          <article class="feature-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Качество и работа с сетями"
        title="Как эта тема поддерживает B2B-диалог"
        text="Страница не дублирует раздел «Для сетей», а усиливает его: сначала объясняет продуктовый подход, затем переводит в документы, переговорный сценарий и контакты."
      />

      <div class="cards-grid">
        {retailQuality.map((item) => (
          <article class="feature-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
            <div class="button-group button-group--spaced">
              <a class="button button--ghost" href={item.href}>{item.cta}</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="cta-strip surface-card">
        <p class="eyebrow">Следующий шаг</p>
        <h2>После этой страницы логично переходить в документы, B2B-раздел или в прямой контакт</h2>
        <p>
          Если нужны подтверждающие материалы, используйте раздел документов.
          Если вы оцениваете продукт для матрицы, переходите в «Для сетей». Если
          нужен прямой диалог, используйте контакты.
        </p>
        <div class="button-group">
          <a class="button" href="/dokumenty/">Документы</a>
          <a class="button button--secondary" href="/partneram/">Для сетей</a>
          <a class="button button--ghost" href="/kontakty/">Связаться</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

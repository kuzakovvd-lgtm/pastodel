---
import BaseLayout from "../layouts/BaseLayout.astro";

const specializationCards = [
  {
    title: "Фокус на готовых замороженных блюдах",
    text: "Pastodel подаётся как производитель продукта для повседневного спроса.",
  },
  {
    title: "Работа на повседневный сценарий покупки",
    text: "Продуктовая логика строится вокруг вкусов и форматов, которые не требуют сложной коммуникации.",
  },
  {
    title: "Маршрут для партнёров вынесен отдельно",
    text: "Для делового диалога уже есть отдельный B2B-раздел и форма запроса.",
  },
];

const approachCards = [
  {
    title: "Продукт как практичное решение",
    text: "В фокусе — понятные блюда, формат упаковки и сценарий использования дома.",
  },
  {
    title: "Ассортимент как структура",
    text: "Линейка разведена по ролям и вкусовым сценариям, чтобы в ней было проще ориентироваться.",
  },
  {
    title: "Контент готов к уточнению",
    text: "Подтверждённые данные по качеству, производству и документам должны добавляться отдельными блоками.",
  },
];
---

<BaseLayout
  title="О компании Pastodel"
  description="Pastodel как производитель готовых замороженных блюд: продуктовый фокус, подход к ассортименту, качеству и деловому диалогу."
  canonical="/o-kompanii/"
>
  <section class="page-intro">
    <div class="container page-intro__inner">
      <p class="eyebrow">О компании</p>
      <h1>Pastodel — производитель готовых замороженных блюд для retail и партнёрского диалога</h1>
      <p>Здесь собраны базовые и подтверждаемые тезисы о продукте, структуре ассортимента и маршрутах для дальнейшего диалога.</p>
    </div>
  </section>

  <section class="section section--tight-top">
    <div class="container">
      <div class="pd-section-head">
        <p class="pd-eyebrow">Кто мы</p>
        <h2>Pastodel сфокусирован на готовом продукте с понятной логикой для полки и покупателя</h2>
        <p class="pd-lead">В центре — готовые замороженные блюда, базовый формат 400 г и короткий путь от выбора до приготовления дома.</p>
      </div>
      <div class="pd-grid pd-grid--3">
        {specializationCards.map((item) => (
          <article class="pd-feature-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="pd-section-head">
        <p class="pd-eyebrow">Подход к ассортименту</p>
        <h2>Как Pastodel подходит к ассортименту</h2>
      </div>
      <div class="pd-grid pd-grid--3">
        {approachCards.map((item) => (
          <article class="pd-feature-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-grid">
      <article class="partner-card">
        <p class="eyebrow">Юридическая информация</p>
        <h2>Юридическая информация</h2>
        <p>Юридические и регистрационные данные публикуются после завершения внутренней проверки.</p>
      </article>

      <article class="partner-card">
        <p class="eyebrow">Следующий шаг</p>
        <h2>Для делового диалога уже есть отдельный B2B-раздел и форма запроса.</h2>
        <div class="button-group button-group--spaced">
          <a class="button" href="/partneram/">Для сетей</a>
          <a class="button button--ghost" href="/kontakty/">Связаться</a>
        </div>
      </article>
    </div>
  </section>
</BaseLayout>

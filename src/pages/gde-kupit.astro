---
import BaseLayout from "../layouts/BaseLayout.astro";

const searchChannels = [
  {
    title: "Каталог SKU",
    text: "Если вы ещё выбираете вкус, начните с раздела продукции. Там собраны SKU и карточки товаров с описанием.",
    href: "/katalog/",
    cta: "Перейти в каталог",
  },
  {
    title: "Карточки товаров",
    text: "Если вас интересует конкретная позиция, откройте страницу SKU. Это самый короткий путь к вкусу, формату, хранению и способу приготовления.",
    href: "/katalog/",
    cta: "Открыть SKU",
  },
  {
    title: "Уточнение наличия",
    text: "Если важно понять, где искать продукт в вашем сценарии покупки, используйте маршрут запроса через контакты.",
    href: "/kontakty/",
    cta: "Уточнить наличие",
  },
];

const availabilitySteps = [
  {
    title: "Выберите SKU или вкус",
    text: "Каталог помогает быстро понять, какую позицию вы ищете.",
  },
  {
    title: "Перейдите в карточку товара",
    text: "На странице SKU уже собраны подтверждённые данные по вкусу, составу, приготовлению и формату упаковки.",
  },
  {
    title: "Уточните сценарий покупки",
    text: "Если нужен ответ по представленности, используйте страницу контактов.",
  },
];
---

<BaseLayout
  title="Где искать продукцию Pastodel"
  description="Где искать продукцию Pastodel: как выбрать SKU, куда перейти за деталями товара и как уточнить наличие."
  canonical="/gde-kupit/"
>
  <section class="page-intro">
    <div class="container page-intro__inner">
      <p class="eyebrow">Где купить</p>
      <h1>Где искать продукцию Pastodel</h1>
      <p>Начните с каталога и карточки нужного SKU, затем используйте маршрут уточнения наличия.</p>
      <div class="button-group">
        <a class="button" href="/katalog/">Перейти в каталог</a>
        <a class="button button--secondary" href="/kontakty/">Уточнить наличие</a>
      </div>
    </div>
  </section>

  <section class="section section--tight-top">
    <div class="container">
      <div class="pd-section-head">
        <p class="pd-eyebrow">С чего начать</p>
        <h2>Три маршрута поиска продукта</h2>
      </div>
      <div class="pd-grid pd-grid--3">
        {searchChannels.map((item) => (
          <article class="pd-channel-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
            <div class="button-group button-group--spaced">
              <a class="pd-button pd-button--ghost" href={item.href}>{item.cta}</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="pd-section-head">
        <p class="pd-eyebrow">Как уточнить</p>
        <h2>Как действовать, если нужен конкретный вкус</h2>
      </div>
      <div class="pd-grid pd-grid--3">
        {availabilitySteps.map((item) => (
          <article class="pd-feature-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="pd-section-head">
        <p class="pd-eyebrow">FAQ</p>
        <h2>FAQ</h2>
      </div>
      <div class="pd-faq" data-accordion>
        <div class="pd-faq__item">
          <button class="pd-faq__button" type="button" aria-expanded="false">Где можно купить Pastodel?</button>
          <div class="pd-faq__panel">
            <p>Используйте каталог и карточку нужного SKU, затем переходите к маршруту уточнения наличия.</p>
          </div>
        </div>
        <div class="pd-faq__item">
          <button class="pd-faq__button" type="button" aria-expanded="false">Как узнать наличие?</button>
          <div class="pd-faq__panel">
            <p>Если нужен ответ по конкретному вкусу или SKU, используйте форму на странице «Контакты» или маршрут запроса со страницы «Где купить».</p>
          </div>
        </div>
        <div class="pd-faq__item">
          <button class="pd-faq__button" type="button" aria-expanded="false">Можно ли заказать онлайн?</button>
          <div class="pd-faq__panel">
            <p>Онлайн-каналы нужно выводить только после подтверждения. Не добавлять их без данных.</p>
          </div>
        </div>
        <div class="pd-faq__item">
          <button class="pd-faq__button" type="button" aria-expanded="false">Где смотреть состав и способ приготовления?</button>
          <div class="pd-faq__panel">
            <p>Эти данные уже собраны в карточках SKU.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="pd-section pd-buy-channels pd-is-hidden">
    <!-- заполнить после передачи подтверждённых логотипов и каналов продаж -->
  </section>
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";

const searchChannels = [
  {
    title: "Каталог SKU",
    text: "Если вы еще выбираете вкус, начните с раздела продукции. Там собраны все SKU и отдельные карточки товаров с описанием вкуса, состава и приготовления.",
    href: "/katalog/",
    cta: "Перейти в каталог",
  },
  {
    title: "Карточки товаров",
    text: "Если вас интересует конкретная позиция, открывайте страницу SKU. Это самый короткий путь к вкусу, формату, хранению и способу приготовления.",
    href: "/katalog/",
    cta: "Открыть SKU",
  },
  {
    title: "Уточнение наличия",
    text: "Если важно понять, где искать продукт в вашем сценарии покупки, используйте раздел контактов. Сейчас страница не изображает locator и не показывает неподтвержденные точки продаж.",
    href: "/kontakty/",
    cta: "Связаться",
  },
];

const availabilitySteps = [
  {
    title: "Выберите SKU или вкус",
    text: "Каталог помогает быстро понять, какую позицию вы ищете: классическую, более сытную или более легкую.",
  },
  {
    title: "Перейдите в карточку товара",
    text: "На product page уже собраны подтвержденные данные по вкусу, составу, приготовлению и формату упаковки.",
  },
  {
    title: "Уточните сценарий покупки",
    text: "Если нужен ответ по представленности, используйте контакты. Так страница остается честной и не обещает несуществующий store locator.",
  },
];

const routeLinks = [
  {
    title: "Для покупателя",
    text: "Начните с каталога и карточек SKU, чтобы выбрать вкус и понять, что именно вы ищете.",
    href: "/katalog/",
  },
  {
    title: "Для сетей",
    text: "Если ассортимент интересен для запуска, переходите в отдельный B2B-раздел «Для сетей».",
    href: "/partneram/",
  },
  {
    title: "Для запроса по наличию",
    text: "Если нужен ручной маршрут без карты и без списка точек, используйте общую страницу контактов.",
    href: "/kontakty/",
  },
];
---

<BaseLayout
  title="Где искать продукцию Pastodel"
  description="Где искать продукцию Pastodel: как выбрать SKU, куда перейти за деталями товара и как уточнить наличие без фейкового locator."
  canonical="/gde-kupit/"
>
  <section class="page-intro">
    <div class="container page-intro__inner">
      <p class="eyebrow">Где купить</p>
      <h1>Где искать продукцию Pastodel</h1>
      <p>
        Эта страница не изображает карту точек продаж и не показывает
        неподтвержденные сети. Ее задача проще: помочь понять, где искать
        продукт, как уточнить наличие и куда идти дальше за конкретным SKU или
        B2B-запросом.
      </p>
      <div class="button-group">
        <a class="button" href="/katalog/">Перейти в каталог</a>
        <a class="button button--secondary" href="/kontakty/">Уточнить наличие</a>
      </div>
    </div>
  </section>

  <section class="section section--tight-top">
    <div class="container">
      <SectionHeading
        eyebrow="С чего начать"
        title="Три честных маршрута поиска продукта"
        text="Вместо фейкового locator страница сразу подсказывает, как действовать в зависимости от сценария."
      />

      <div class="channels-grid">
        {searchChannels.map((item) => (
          <article class="channel-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
            <div class="button-group button-group--spaced">
              <a class="button button--ghost" href={item.href}>{item.cta}</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Как уточнить"
        title="Как действовать, если нужен конкретный вкус или ответ по представленности"
        text="Блок нужен для практического сценария: выбрать SKU, открыть карточку и только потом уточнять наличие."
      />

      <div class="cards-grid">
        {availabilitySteps.map((item) => (
          <article class="feature-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Переходы"
        title="Куда идти дальше"
        text="Страница работает как честный маршрутизатор: в каталог, в контакты или в B2B-раздел."
      />

      <div class="cards-grid">
        {routeLinks.map((item) => (
          <article class="feature-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
            <div class="button-group button-group--spaced">
              <a class="button button--ghost" href={item.href}>Открыть раздел</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="partner-band surface-card">
        <p class="eyebrow">Для сетей</p>
        <h2>Если продукт интересен для запуска, используйте отдельный B2B-маршрут</h2>
        <p>
          Покупательский сценарий на этой странице заканчивается каталогом и
          контактами. Для сети, дистрибьютора или пилотного запуска на сайте уже
          подготовлен отдельный раздел «Для сетей».
        </p>
        <div class="button-group">
          <a class="button" href="/partneram/">Перейти в раздел для сетей</a>
          <a class="button button--ghost" href="/dokumenty/">Документы</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="cta-strip surface-card">
        <p class="eyebrow">Следующий шаг</p>
        <h2>Сначала выберите SKU, затем уточните наличие или откройте B2B-раздел</h2>
        <p>
          Страница не обещает то, чего пока нет в проекте. Вместо этого она
          помогает быстро перейти в продукцию, контакты или маршрут для торговых
          сетей.
        </p>
        <div class="button-group">
          <a class="button" href="/katalog/">Каталог</a>
          <a class="button button--secondary" href="/kontakty/">Контакты</a>
          <a class="button button--ghost" href="/partneram/">Для сетей</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
